{"parent":"product.json","context":{"market":"singapore"},"sections":{"main":{"settings":{},"blocks":{"custom_DXEcp6":{"settings":{"code":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<title>Collapsible Promo Code Block<\/title>\n<style>\n    .collapsible {\n        cursor: pointer;\n        padding: 10px 15px; \/* Reduced padding *\/\n        width: 100%;\n        background-color: #f0f0f0; \/* Light grey background *\/\n        border: none;\n        text-align: center;\n        outline: none;\n        border-radius: 5px; \/* Rounded corners *\/\n        box-shadow: 0 4px 8px rgba(0,0,0,0.1); \/* Subtle shadow *\/\n        font-family: inherit; \/* Inherits font from the body or surrounding text *\/\n        color: inherit; \/* Inherits text color from the body or surrounding text *\/\n        display: flex;\n        justify-content: center;\n        align-items: center;\n        font-size: 16px; \/* Adjusted font size *\/\n    }\n\n    .collapsible.active, .collapsible:hover {\n        background-color: #e0e0e0; \/* Slightly darker grey on hover\/active *\/\n    }\n\n    .plus {\n        margin-left: auto;\n        margin-right: 10px; \/* Reduced margin-right *\/\n        font-size: 1.5em; \/* Adjusted size to fit on mobile screens *\/\n    }\n\n    .content {\n        padding: 10px 15px; \/* Adjusted padding *\/\n        display: none;\n        overflow: hidden;\n        background-color: #f9f9f9;\n        transition: max-height 0.2s ease-out;\n        width: 100%;\n        box-sizing: border-box;\n        font-size: inherit; \/* Ensures the font size matches the surrounding text *\/\n    }\n\n    \/* Media Query for Mobile Devices *\/\n    @media (max-width: 600px) {\n        .collapsible {\n            padding: 8px 10px; \/* Further reduce padding for smaller screens *\/\n            font-size: 14px; \/* Smaller font size to fit content in one line *\/\n        }\n        .plus {\n            margin-right: 5px; \/* Smaller margin for plus icon *\/\n        }\n    }\n<\/style>\n<\/head>\n<body>\n\n<div class=\"collapsible\">\n    🎉 Get this at 20% off <span class=\"plus\">+<\/span>\n<\/div>\n<div class=\"content\">\n    <p>Use INDO20 at checkout to get 20% off your purchase above SGD 350 along with free shipping, and INDO15 to get 15% off your purchase above SGD270 with free shipping. Valid for all items!<\/p>\n<\/div>\n\n<script>\n    var coll = document.querySelector(\".collapsible\");\n    var content = document.querySelector(\".content\");\n\n    coll.addEventListener(\"click\", function() {\n        this.classList.toggle(\"active\");\n        var plus = this.querySelector(\".plus\");\n        if (content.style.display === \"block\") {\n            content.style.display = \"none\";\n            plus.innerHTML = '+';\n        } else {\n            content.style.display = \"block\";\n            plus.innerHTML = '-';\n        }\n    });\n<\/script>\n\n<\/body>\n<\/html>"}},"text_tVXE8P":{"settings":{"text":"(For custom size and\/or custom style, a fee of SGD 6.8 for dresses, and SGD 10 for blazers per item will apply)"}},"tab":{"settings":{"content":"<p>Products are shipped within 3-6 days of receiving the order, and delivery takes 3-12 Business Days depending on the shipping speed selected. <\/p><p>Returns can be done within 14 days of receiving the order. <\/p><p>We offer a fit guarantee in Singapore. If you don't like the product, we remake it for free. <\/p>"}}}}}}