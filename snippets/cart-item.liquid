<div
  class="cart__item {% if product.properties['_custom lining'] %} main-custom-lining {% endif %}"
  data-key="{{ product.key }}"
  {% if product.properties['Customization charge'] %}
    style="display:none"
  {% endif %}
>
  {%- assign img_url = product | img_url: '1x1' | replace: '_1x1.', '_{width}x.' -%}
  <div class="cart__image">
    <a href="{{ product.url }}" style="height: 0; padding-bottom: {{ 100 | divided_by: product.image.aspect_ratio }}%;">
      {% assign api_image_url = '' %}
      {% for p in product.properties %}
        {%- assign first_character_in_key = p.first -%}
        {% if first_character_in_key == 'Customized image' %}
          {% assign api_image_url = p.last %}
        {% endif %}
      {% endfor %}

      {% if api_image_url != blank %}
        <img
          class="lazyload"
          data-src="{{ api_image_url }}"
          data-widths="[180, 360, 540]"
          data-aspectratio="{{ product.aspect_ratio }}"
          data-sizes="auto"
          alt="{{ product.product.title | escape }}"
        >
      {% else %}
        <img
          class="lazyload"
          data-src="{{ img_url }}"
          data-widths="[180, 360, 540]"
          data-aspectratio="{{ product.aspect_ratio }}"
          data-sizes="auto"
          alt="{{ product.product.title | escape }}"
        >
      {% endif %}
      <noscript>
        <img
          class="lazyloaded"
          src="{{ product | img_url: '400x' }}"
          alt="{{ product.product.title | escape }}"
        >
      </noscript>
    </a>
  </div>
  <div class="cart__item-details">
    <div class="cart__item-title">
      <a href="{{ product.url }}" class="cart__item-name">
        {{ product.product.title }}
      </a>
      {%- unless product.product.has_only_default_variant -%}
        <div class="cart__item--variants">
          {%- for option in product.options_with_values -%}
            <div>
              <span>{{ option.name }}:</span> {{ option.value }}
            </div>
          {%- endfor -%}
        </div>
      {%- endunless -%}
      {%- if product.selling_plan_allocation != empty -%}
        <div class="cart__item--variants">
          {{ product.selling_plan_allocation.selling_plan.name }}
        </div>
      {%- endif -%}
      {%- assign property_size = product.properties | size -%}
      {% if property_size > 0 %}
        {% assign style_properties = 'Neckline,Sleevetype,Bottomlength,Pantlength' | split: ',' %}
        {% assign style_shown = false %}
        {% assign size_shown = false %}

        {% for p in product.properties %}
          {%- assign first_character_in_key = p.first | truncate: 1, '' -%}
          {% unless p.last == blank or first_character_in_key == '_' or p.first == 'Customized image' %}
            {% if style_properties contains p.first %}
              {% unless style_shown %}
                <p class="propertyHeading"><strong>Style</strong></p>
                {% assign style_shown = true %}
              {% endunless %}
            {% else %}
              {% unless size_shown %}
                <p class="propertyHeading"><strong>Size</strong></p>
                {% assign size_shown = true %}
              {% endunless %}
            {% endif %}

            <div>
              {{ p.first }}:
              {% if p.last contains '/uploads/' %}
                <a href="{{ p.last }}">{{ p.last | split: '/' | last }}</a>
              {% else %}
                <span class="property_value">{{ p.last }}</span>
              {% endif %}
            </div>
          {% endunless %}
        {% endfor %}
      {% endif %}
    </div>
    <div class="cart__item-sub">
      <div>
        <div class="js-qty__wrapper">
          <label for="cart_updates_{{ product.key }}" class="hidden-label">{{ 'cart.label.quantity' | t }}</label>
          <input
            type="text"
            id="cart_updates_{{ product.key }}"
            name="updates[]"
            class="js-qty__num"
            value="{{ product.quantity }}"
            min="0"
            pattern="[0-9]*"
            data-id="{{ product.key }}"
          >
          <button
            type="button"
            class="js-qty__adjust js-qty__adjust--minus"
            aria-label="{{ 'cart.general.reduce_quantity' | t }}"
          >
            <svg aria-hidden="true" focusable="false" role="presentation" class="icon icon-minus" viewBox="0 0 20 20">
              <path fill="#444" d="M17.543 11.029H2.1A1.032 1.032 0 0 1 1.071 10c0-.566.463-1.029 1.029-1.029h15.443c.566 0 1.029.463 1.029 1.029 0 .566-.463 1.029-1.029 1.029z"/>
            </svg>
            <span class="icon__fallback-text" aria-hidden="true">&minus;</span>
          </button>
          <button
            type="button"
            class="js-qty__adjust js-qty__adjust--plus"
            aria-label="{{ 'cart.general.increase_quantity' | t }}"
          >
            <svg aria-hidden="true" focusable="false" role="presentation" class="icon icon-plus" viewBox="0 0 20 20">
              <path fill="#444" d="M17.409 8.929h-6.695V2.258c0-.566-.506-1.029-1.071-1.029s-1.071.463-1.071 1.029v6.671H1.967C1.401 8.929.938 9.435.938 10s.463 1.071 1.029 1.071h6.605V17.7c0 .566.506 1.029 1.071 1.029s1.071-.463 1.071-1.029v-6.629h6.695c.566 0 1.029-.506 1.029-1.071s-.463-1.071-1.029-1.071z"/>
            </svg>
            <span class="icon__fallback-text" aria-hidden="true">+</span>
          </button>
        </div>

        <div class="cart__remove">
          <a href="{{ routes.cart_change_url }}?id={{ product.key }}&amp;quantity=0" class="text-link">
            {{ 'cart.general.remove' | t }}
          </a>
        </div>
      </div>

      <div class="cart__item-price-col text-right">
        {% if product.original_price != product.final_price %}
          <span class="visually-hidden">{{ 'products.general.regular_price' | t }}</span>
          <small class="cart__price cart__price--strikethrough">
            <span data-ymq-item-key="{{ product.key }}" class="ymq_item_original_price">
              {{- product.original_price | money -}}
            </span>
          </small>
          <span class="visually-hidden">{{ 'products.general.sale_price' | t }}</span>
          <span class="cart__price cart__discount">
            <span data-ymq-item-key="{{ product.key }}" class="ymq_item_final_price">
              {{- product.final_price | money -}}
            </span>
          </span>
        {% else %}
          <span class="cart__price">
            <span data-ymq-item-key="{{ product.key }}" class="ymq_item_original_price">
              {{- product.original_price | money -}}
            </span>
          </span>
        {% endif %}

        {%- if product.line_level_discount_allocations != blank -%}
          {%- for discount_allocation in product.line_level_discount_allocations -%}
            <small class="cart__discount">
              {{- discount_allocation.discount_application.title }} (-{{ discount_allocation.amount | money }})</small
            >
          {%- endfor -%}
        {%- endif -%}

        {%- if product.unit_price_measurement -%}
          {%- capture unit_price_base_unit -%}
            <span class="unit-price-base">
              {%- if product.unit_price_measurement -%}
                {%- if product.unit_price_measurement.reference_value != 1 -%}
                  <span data-ymq-item-key="{{ product.key }}" class='ymq_item_unit_price_measurement'>{{ product.unit_price_measurement.reference_value }}</span>
                {%- endif -%}
                <span data-ymq-item-key="{{ product.key }}" class='ymq_item_unit_price_measurement'>{{ product.unit_price_measurement.reference_unit }}</span>
              {%- endif -%}
            </span>
          {%- endcapture -%}

          <div class="product__unit-price">
            <span data-ymq-item-key="{{ product.key }}" class="ymq_item_unit_price">
              {{- product.unit_price | money -}}</span
            >/{{ unit_price_base_unit }}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>
 {% for p in product.properties %}
   {% if p.first contains '_custom lining' %}
    <div class="custom-lining-charge">
      <div class="lining-charge-image">
        <img src ="{{ settings.lining_extra_charge_product.featured_image|image_url }}" height="auto" width="auto" />
      </div>
      <div class="lining-charge-details">
        <div class="lining-charge-title">{{ settings.lining_extra_charge_product.title }}</div>
        <div class="lining-charge-price">{{ settings.lining_extra_charge_product.price | money }}</div>
        <span class="custom-charge-product" id = {{ product.key }}>Remove</span>
      </div>
    </div>
  {% endif %}
 {% endfor %}
{% comment %}<!-- ymq option done -->{% endcomment %}
