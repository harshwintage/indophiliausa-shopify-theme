{% doc %}
  @prompt
    four images - two in each row - with no space between them. images should be clickable and linked to collection
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-collection-grid-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-collection-grid__wrapper-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    grid-template-rows: repeat(2, 1fr);
    gap: 0;
    width: 100%;
  }

  .ai-collection-grid__item-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    aspect-ratio: 1;
  }

  .ai-collection-grid__link-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    height: 100%;
    position: relative;
  }

  .ai-collection-grid__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-collection-grid__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-collection-grid__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
  }
{% endstyle %}

<collection-grid-{{ ai_gen_id }} class="ai-collection-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-collection-grid__wrapper-{{ ai_gen_id }}">
    {% for i in (1..4) %}
      {% liquid
        assign collection_key = 'collection_' | append: i
        assign collection = block.settings[collection_key]
      %}
      
      <div class="ai-collection-grid__item-{{ ai_gen_id }}">
        {% if collection != blank %}
          <a href="{{ collection.url }}" class="ai-collection-grid__link-{{ ai_gen_id }}">
            {% if collection.image %}
              <img
                src="{{ collection.image | image_url: width: 800 }}"
                alt="{{ collection.image.alt | escape }}"
                width="{{ collection.image.width }}"
                height="{{ collection.image.height }}"
                loading="lazy"
                class="ai-collection-grid__image-{{ ai_gen_id }}"
              >
            {% elsif collection.products.first and collection.products.first.featured_image %}
              <img
                src="{{ collection.products.first.featured_image | image_url: width: 800 }}"
                alt="{{ collection.products.first.featured_image.alt | escape }}"
                width="{{ collection.products.first.featured_image.width }}"
                height="{{ collection.products.first.featured_image.height }}"
                loading="lazy"
                class="ai-collection-grid__image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-collection-grid__placeholder-{{ ai_gen_id }}">
                {{ 'collection-apparel-1' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </a>
        {% else %}
          <div class="ai-collection-grid__placeholder-{{ ai_gen_id }}">
            {{ 'collection-apparel-1' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</collection-grid-{{ ai_gen_id }}>

{% schema %}
{
  "name": "Collection grid",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Collections"
    },
    {
      "type": "collection",
      "id": "collection_1",
      "label": "Collection 1"
    },
    {
      "type": "collection",
      "id": "collection_2",
      "label": "Collection 2"
    },
    {
      "type": "collection",
      "id": "collection_3",
      "label": "Collection 3"
    },
    {
      "type": "collection",
      "id": "collection_4",
      "label": "Collection 4"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Collection grid"
    }
  ]
}
{% endschema %}
